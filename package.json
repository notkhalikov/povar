{
  "name": "@povar/api",
  "version": "0.0.1",
  "private": true,
  "description": "Povar API service",
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/websocket": "^8.3.0",
    "fastify": "^4.28.1",
    "dotenv": "^16.4.0",
    "postgres": "^3.4.3",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "eslint": "^9.0.0",
    "typescript": "^5.4.5",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}